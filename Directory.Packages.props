    <PackageVersion Include="MinVer" Version="7.0.0" />
    <PackageVersion Include="Testcontainers.MsSql" Version="4.12.0" />
    <PackageVersion Include="TUnit" Version="1.47.0" />
  </ItemGroup>
</Project>